#!/bin/sh
#
# pass a param to create i686+x86_64 sfs
#

### http://linux.palemoon.org/download/mainline/
VERSION_i686=28.16.0
URL_i686="http://linux.palemoon.org/datastore/release/palemoon-${VERSION}.linux-i686.tar.xz"
URL_x86_64="http://linux.palemoon.org/datastore/release/palemoon-${VERSION}.linux-x86_64.tar.xz"

### https://github.com/gorhill/uBlock-for-firefox-legacy/releases
UB_VERSION=1.16.4.26
UB_URL="https://github.com/gorhill/uBlock-for-firefox-legacy/releases/download/firefox-legacy-${UB_VERSION}/uBlock0_${UB_VERSION}.firefox-legacy.xpi"

#=========================================================

S_COMP="-comp gzip" #xz gzip lzo lz4
OUTPUT_DIR=${PWD}/output
mkdir -p ${PWD}/output

SPLIT=1
if [ "$1" ] ; then
	SPLIT=
	[ "$1" = "pet" ] && PET=1
fi

case $0 in
	*unified*) SPLIT=  ;;
	*split)    SPLIT=1 ;;
esac

#=========================================================

mkdir -p tmp
cd tmp

CWD=$(pwd)

cleanup() {
	if [ -s /tmp/dlxxmm$$ ] ; then
		rm -f $(cat /tmp/dlxxmm$$)
		rm -f /tmp/dlxxmm$$
	fi
}

trap cleanup EXIT

dl_file() { #url
	url=${1}
	file=${url##*/} # basename
	if ! [ -f "$file" ] ; then
		echo $PWD/${file} > /tmp/dlxxmm$$
		if ! wget --no-check-certificate "$url" ; then
			rm -f "$file"
			exit 1
		fi
		sync
		rm -f /tmp/dlxxmm$$
	fi
}

ublock_origin=${PWD}/${UB_URL##*/} #basename
dl_file ${UB_URL}
dl_file ${URL_i686}
dl_file ${URL_x86_64}

#======================================================================

if ! [ "$SPLIT" ] ; then
	PKGDIR=palemoon-${VERSION}-i686-x86_64-ubo
	#--
	mkdir -p ${PKGDIR}/opt/palemoon
	mkdir -p ${PKGDIR}/usr/bin
	mkdir -p ${PKGDIR}/usr/share/applications
	mkdir -p ${PKGDIR}/usr/share/pixmaps
	(
	cd ${PKGDIR}/opt/palemoon
	rm -rf i686 x86_64
	tar -xf $CWD/${URL_x86_64##*/} && mv palemoon x86_64
	tar -xf $CWD/${URL_i686##*/} && mv palemoon i686
	)
	#--
	cp ${PKGDIR}/opt/palemoon/x86_64/browser/icons/mozicon128.png ${PKGDIR}/usr/share/pixmaps
fi

#======================================================================

pm_default_config() {
	for i in root home/spot home/finn
	do
		mkdir -p "${PKGDIR}/${i}/.moonchild productions/pale moon/1yhyegqn.default"
		cat > "${PKGDIR}/${i}/.moonchild productions/pale moon/profiles.ini" <<EOF
[General]
StartWithLastProfile=1

[Profile0]
Name=default
IsRelative=1
Path=1yhyegqn.default
Default=1
EOF
		cat > "${PKGDIR}/${i}/.moonchild productions/pale moon/1yhyegqn.default/prefs.js" <<EOF
# Mozilla User Preferences

//user_pref("browser.cache.disk.capacity", 51200);
user_pref("browser.cache.disk.capacity", 30720);
user_pref("browser.cache.disk.smart_size.enabled", false);
user_pref("browser.search.defaultenginename", "Google");
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.startup.homepage", "about:blank");
user_pref("browser.startup.page", 0);
EOF
		chmod 600 "${PKGDIR}/${i}/.moonchild productions/pale moon/1yhyegqn.default/prefs.js"
	done
	chown spot    "${PKGDIR}/home/spot/"
	chown -R spot "${PKGDIR}/home/spot/.moonchild productions"
	#--
	chown finn    "${PKGDIR}/home/finn/"
	chown -R finn "${PKGDIR}/home/finn/.moonchild productions"
	#--
}

#======================================================================
# TODO
lang_packs() {
	mkdir -p $CWD/langpacks
	if [ ! -f $CWD/langpacks/pm-localeswitch@palemoon.org.xpi ] ; then
		wget --no-check-certificate \
			-O pm-localeswitch@palemoon.org.xpi
			https://addons.palemoon.org/?component=download&id=pm-localeswitch@palemoon.org
	fi
	#langpack-en-GB langpack-es-AR langpack-es-MX langpack-pt-BR
	for i in \
		bg cs de el es-ES \
		fr hu it ko nl pl \
		pt-PT ru sv-SE tl \
		tr uk zh-CN
	do
		if [ ! -f $CWD/langpacks/langpack-${i}@palemoon.org.xpi ] ; then
			wget --no-check-certificate \
				-O langpack-${i}@palemoon.org.xpi
				https://addons.palemoon.org/?component=download&id=langpack-${i}@palemoon.org
		fi
	done
}
#lang_packs

#======================================================================

for i in i686 x86_64
do

	cd $CWD

	if [ "$SPLIT" ] ; then
		case $i in
			i686)   URL=${URL_i686}   ;;
			x86_64) URL=${URL_x86_64} ;;
		esac
		FILE=${URL##*/}
		PKGDIR=${FILE%.tar.*}
		PKGDIR=${PKGDIR//.linux/}
		PKGDIR=${PKGDIR}-ubo
		i=
		mkdir -p ${PKGDIR}/opt
		mkdir -p ${PKGDIR}/usr/bin
		mkdir -p ${PKGDIR}/usr/share/applications
		mkdir -p ${PKGDIR}/usr/share/pixmaps
		( cd ${PKGDIR}/opt ; tar -xf $CWD/${FILE} ; )
		cp ${PKGDIR}/opt/palemoon/browser/icons/mozicon128.png ${PKGDIR}/usr/share/pixmaps
	fi

	for j in ${PKGDIR}/opt/palemoon/${i}/omni.ja ${PKGDIR}/opt/palemoon/${i}/browser/omni.ja
	do
		[ -f $j ] || continue
	(
		dir=$(dirname $j)
		cd $dir
		mkdir omnidir
		cd omnidir
		unzip ../omni.ja
		sync
		zip -0 -y -R ../newomni '*'
		cd ..
		mv newomni.zip omni.ja
		rm -r omnidir
	)
	done

	#------------------
	echo '#!/bin/sh' > ${PKGDIR}/usr/bin/palemoon
	if ! [ "$SPLIT" ] ; then
		echo 'exec /opt/palemoon/$(uname -m)/palemoon "$@"' >> ${PKGDIR}/usr/bin/palemoon
	else
		echo 'exec /opt/palemoon/palemoon "$@"' >> ${PKGDIR}/usr/bin/palemoon
	fi
	chmod +x ${PKGDIR}/usr/bin/palemoon
	#------------------

	cat > ${PKGDIR}/usr/share/applications/palemoon.desktop <<EOF
[Desktop Entry]
Encoding=UTF-8
Name=Pale Moon
Icon=/usr/share/pixmaps/mozicon128.png
Comment=Pale Moon web browser
Exec=palemoon
Terminal=false
Type=Application
Categories=WebBrowser
MimeType=text/html;text/xml;application/xhtml+xml;application/xml;application/rss+xml;application/rdf+xml;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/ftp;x-scheme-handler/chrome;video/webm;application/x-xpinstall;
GenericName=Palemoon web browser
EOF

	cat > ${PKGDIR}/opt/palemoon/${i}/browser/searchplugins/google.xml <<EOF
<SearchPlugin xmlns="http://www.mozilla.org/2006/browser/search/" xmlns:os="http://a9.com/-/spec/opensearch/1.1/">
<os:ShortName>Google</os:ShortName>
<os:Description>Google Search</os:Description>
<os:InputEncoding>UTF-8</os:InputEncoding>
<os:Image width="16" height="16">data:image/x-icon;base64,</os:Image>
<SearchForm>https://www.google.com/</SearchForm>
<os:Url type="application/x-suggestions+json" method="GET" template="https://suggestqueries.google.com/complete/search?output=firefox&amp;client=firefox&amp;q={searchTerms}" resultDomain="suggestqueries.google.com">
</os:Url><os:Url type="text/html" method="GET" template="https://www.google.com/search" resultDomain="google.com">
  <os:Param name="q" value="{searchTerms}"/>
  <os:Param name="ie" value="utf-8"/>
  <os:Param name="oe" value="utf-8"/>
</os:Url>
</SearchPlugin>
EOF

	echo '#!/bin/sh
LAUNCHDIR="$(dirname "$(readlink -f "$0")")"
mkdir "$LAUNCHDIR/profile" 2> /dev/null
exec "$LAUNCHDIR/palemoon" "$@" -profile "$LAUNCHDIR/profile"
' > ${PKGDIR}/opt/palemoon/${i}/palemoon-portable
	chmod +x ${PKGDIR}/opt/palemoon/${i}/palemoon-portable

	cp -f ${ublock_origin} ${PKGDIR}/opt/palemoon/${i}/browser/extensions/uBlock0@raymondhill.net.xpi
	#cp -f ${CWD}/langpacks/*.xpi ${PKGDIR}/opt/palemoon/${i}/browser/extensions/
	pm_default_config

	if [ "$SPLIT" ] ; then
		cd $CWD
		if [ "$PET" ] ; then
			dir2pet -x -s -n ${PKGDIR}
			mv ${PKGDIR}.pet* ${OUTPUT_DIR}
		else
			mksquashfs ${PKGDIR} ${PKGDIR}.sfs ${S_COMP}
			sha256sum ${PKGDIR}.sfs > ${PKGDIR}.sfs.sha256.txt
			mv ${PKGDIR}.sfs* ${OUTPUT_DIR}
		fi
	fi

done

#======================================================================

if [ "$SPLIT" ] ; then
	exit
fi

cd $CWD

rm -f palemoon-${VERSION}-i686-x86_64-ubo.sfs
mksquashfs palemoon-${VERSION}-i686-x86_64-ubo palemoon-${VERSION}-i686-x86_64-ubo.sfs ${S_COMP}
sha256sum palemoon-${VERSION}-i686-x86_64-ubo.sfs > palemoon-${VERSION}-i686-x86_64-ubo.sfs.sha256.txt

mv palemoon-${VERSION}-i686-x86_64-ubo.sfs* ${OUTPUT_DIR}

