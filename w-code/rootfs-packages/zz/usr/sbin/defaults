#w__ 2015
#PUPPY SPECIFIC

# fc-cache -s -v -y rootfs-complete usr/share/fonts
# gtk-update-icon-cache -i -f rootfs-complete/usr/share/icons/hicolor/
# update-mime-database -V rootfs-complete/usr/share/mime/
# glib-compile-schemas rootfs-complete/usr/share/glib-2.0/schemas/
