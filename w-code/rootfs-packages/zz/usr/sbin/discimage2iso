#!/bin/sh
#w__ 2015

# ubuntu lucid ----------------
#b5i2iso_0.2-0ubuntu1_i386.deb
#ccd2iso_0.3-3_i386.deb
#cdi2iso_0.1-0ubuntu1_i386.deb
#daa2iso_0.1.7e-1_i386.deb
#iat_0.1.3-7_i386.deb
#mdf2iso_0.3.0-1_i386.deb
#nrg2iso_0.4-4_i386.deb
#pdi2iso_0.1-0ubuntu1_i386.deb
#uif2iso_0.1.7a-1_i386.deb

function help() {
	echo "Syntax:
	${0##*/} inputfile [outputfile]
	
Supported formats:
	b5i,bwi -  BlindWrite BIN image
	bin - image
	img - IMG format
	cdi -  DiscJuggler image file
	daa,gbi - converts daa (PowerISO) and gbi files to iso format
	mdf - Alcohol 120% .mdf image
	nrg - Nero CD-ROM image file
	pdi - Instant Copy image file into standard ISO image file
	uif - Universal Image Format) image (generated by the MagicISO program)
"
	exit $1
}
case $1 in -h|-help|--help) help ;; esac

inputfile="$1"
outputfile="$2"

if [ ! "$inputfile" ] ; then
	echo "No input file"
	exit 10
fi
if [ ! -f "$inputfile" ] ; then
	echo "* File does no exist/Invalid file: $inputfile"
	exit 11
fi

if [ ! "$outputfile" ] ; then
	outputfile=${inputfile%.*}.iso #remove extension and add .iso
fi

case $outputfile in 
	*.iso|*.ISO) true ;; #ok
	*) outputfile=${outputfile}.iso ;; #fix extension
esac

#################################################################

extension=${inputfile##*.}
#echo $inputfile ; echo $outputfile ; echo $extension ; exit ##DEBUG

case $extension in 
	iso|ISO)
		echo "* Must not process ISO files.."
		exit 12
		;;
	b5i|B5I|bwi|BWI)
		# B5I2ISO is a very simple utility to convert a BlindWrite BIN image to the standard
		#	ISO-9660 format. BlindWrite image can have different extensions like .b5i or .bwi  
		#b5i2iso [OPTION] [BASENAME.b5i]  
		#b5i2iso [OPTION] [BASENAME.bwi]  
		b5i2iso "$inputfile"
		;;
	bin|BIN)
		#Iat (Iso9660 Analyzer Tool) is a tool for detecting the structure of many types of CD-ROM image file formats, such as BIN, MDF, PDI, CDI, NRG, and B5I, and  converting them into ISO-9660.
		# Convert MDF-image to ISO9660: iat my_image.mdf my_new_image.iso
		# Convert BIN-image to ISO9660: iat my_image.bin > my_new_image.iso
		# Write CD directly from MDF-format: iat my_image.mdf | cdrecord -
		iat "$inputfile" > "$outputfile"
		;;
	img|IMG)
		#ccd2iso [FOO.IMG] [BAR.ISO]  
		# ccd2iso - convert IMG format to ISO format  
		#IMG files are raw-data copies of optical media, generated primarily by the Windows application CloneCD, and are primarily used to store CDs with odd properties, such as sectors which need to have read errors when read. Conversion to ISO format removes this information, as ISO format does not support this.
		#LIMITATION: ccd2iso currently only copies the first session of multisession discs, as well as outputting a harmless warning of Unrecognized sector mode. 
		#LIMITATION: ccd2iso utterly ignores the additional data in CCD or SUB files.  
		echo "Choose an option:"
		echo "	1) iat"
		echo "	2) ccd2iso"
		echo
		echo -n "Option: " ; read opt
		case $opt in
			1) iat "$inputfile" > "$outputfile" ;;
			2) ccd2iso "$inputfile" "$outputfile" ;;
			*) echo "* Invalid option" ; exit 30 ;;
		esac
		;;
	cdi|CDI)
		# cdi2iso - convert a DiscJuggler image file into standard ISO image file  
		# cdi2iso FILENAME.cdi FILENAME.iso  
		cdi2iso "$inputfile" "$outputfile"
		;;
	daa|DAA|gbi|GBI)
		# DAA2ISO converts single and multipart DAA (Direct Access Archive) images (generated by the PowerISO program) to their original format.
		#daa2iso <input.daa> <output>  
		# daa2iso - converts daa and gbi files to iso format.  
		daa2iso "$inputfile" "$outputfile"
		;;
	mdf|MDF)
		#Alcohol 120% .mdf image"
		#mdf2iso [OPTION] [BASENAME.MDF] [DESTINATION]
		mdf2iso "$inputfile" "$outputfile"
		;;
	nrg|NRG)
		#Nero '.nrg' CD-ROM image file"
		#nrg2iso [nrg-file] [iso-file]
		nrg2iso "$inputfile" "$outputfile"
		;;
	pdi|PDI)
		 #pdi2iso - convert a Instant Copy image file into standard ISO image file"
		 #pdi2iso [OPTION] [BASENAME.pdi]"
		 pdi2so "$inputfile"
		 ;;
	uif|UIF)
		# UIF2ISO converts single and multipart UIF (Universal Image Format) images (generated by the MagicISO program) to their original format.
		#uif2iso - converts uif files to iso or other formats.  
		#uif2iso <input.UIF> <output>  
		uif2iso "$inputfile" "$outputfile"
		;;
	*)
		echo "Format not supported: $extension"
		exit 20
		;;
esac

### END ###